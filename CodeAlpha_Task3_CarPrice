rage Error: {mean_absolute_error(y_test, y_pred):.2f} Lakh\")\n","\n","plt.figure(figsize=(8,6))\n","plt.scatter(y_test, y_pred, color='blue')\n","plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--')\n","plt.xlabel('Actual Price (Lakh)')\n","plt.ylabel('Predicted Price (Lakh)')\n","plt.title('Car Price Prediction')\n","plt.tight_layout()\n","plt.show()\n","\n","plt.figure(figsize=(8,6))\n","coeff = pd.DataFrame(model.coef_, X.columns, columns=['Coefficient'])\n","sns.barplot(x=coeff.index, y=coeff['Coefficient'])\n","plt.title('Feature Importance')\n","plt.xticks(rotation=45)\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"DONE 🎉\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"L3mKzGRvDLM2","executionInfo":{"status":"ok","timestamp":1780903073571,"user_tz":-330,"elapsed":633,"user":{"displayName":"Seema Yadav","userId":"14788622787614946543"}},"outputId":"10634144-e930-4520-ed5e-a047e0f390cf"},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["Year : 20\n","Present_Price : 20\n","Kms_Driven : 20\n","Fuel_Type : 20\n","Transmission : 20\n","Owner : 20\n","Selling_Price : 20\n","\n","Data ready Seema ✅ Total cars: 20\n","Model trained ✅\n","R2 Score: 0.83\n","Average Error: 0.56 Lakh\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["DONE 🎉\n"]}]}]}